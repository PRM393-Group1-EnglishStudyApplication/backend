{
  "name": "elearning-backend",
  "version": "1.0.0",
  "description": "Monolithic backend cho ung dung hoc tieng Anh (PRM393) - Express + MongoDB + Mongoose + Clerk",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc --project tsconfig.build.json",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "db:seed": "tsx src/seed.ts",
    "lint": "eslint .",
    "test": "node --import tsx --test src/utils/utils.test.ts src/modules/lessons/scoring.test.ts src/modules/tts/tts.test.ts src/modules/notifications/reminder.test.ts src/modules/favorites/favorites.test.ts src/modules/hearts/hearts.test.ts"
  },
  "keywords": [
    "express",
    "mongodb",
    "mongoose",
    "clerk",
    "elearning"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1071.0",
    "@clerk/express": "^2.1.26",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "helmet": "^8.0.0",
    "mongoose": "^9.7.0",
    "morgan": "^1.10.0",
    "multer": "^2.2.0",
    "svix": "^1.95.2",
    "swagger-jsdoc": "^6.3.0",
    "swagger-ui-express": "^5.0.1",
    "winston": "^3.15.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.7.0",
    "eslint": "^9.12.0",
    "mongodb-memory-server": "^11.2.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
